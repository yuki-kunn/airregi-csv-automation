# ===== Firebase（既存 airregi-inventory と同じサービスアカウント） =====
# サービスアカウントJSONをBase64エンコードした文字列
#   cat service-account.json | base64 -w0
FIREBASE_ADMIN_SERVICE_ACCOUNT_KEY=
FIREBASE_ADMIN_PROJECT_ID=ipo-kaidashi

# ===== AirREGI（取得元） =====
# cookie_tool.py で取得したCookieのJSON文字列（[{name,value,domain,...}, ...]）
AIRREGI_COOKIES=
# 任意: cookie_tool.py の画面に表示する参考用（自動ログインは既定で行わない）
AIRREGI_ID=
AIRREGI_PASS=

# ===== 投入先（IPO在庫・売上管理システム） =====
IPO_UPLOAD_PASSWORD=

# ===== Selenium / 実行設定 =====
# ローカルで画面を見ながらデバッグするときは false
HEADLESS=true
# scheduledTime と現在時刻の許容ずれ(分)。cron間隔(10分)以上にする
SCHEDULE_WINDOW_MINUTES=10
